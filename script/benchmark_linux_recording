#!/usr/bin/env bash
set -euo pipefail

root="$(CDPATH= cd -- "$(dirname "$0")/.." && pwd -P)"
output_dir="${WARP_RECORDING_BENCHMARK_OUTPUT_DIR:-${root}/target/recording-benchmark}"
timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
output="${output_dir}/recording-benchmark-${timestamp}.csv"
resolution="${WARP_RECORDING_BENCHMARK_RESOLUTION:-1920x1080}"

if [[ "$(uname -s)" != "Linux" ]]; then
  printf 'This benchmark must run on Linux.\n' >&2
  exit 1
fi
for command in Xvfb ffmpeg cargo; do
  if ! command -v "$command" >/dev/null; then
    printf 'Missing required command: %s\n' "$command" >&2
    exit 1
  fi
done

mkdir -p "$output_dir"
display_number=100
while [[ -e "/tmp/.X${display_number}-lock" ]]; do
  display_number=$((display_number + 1))
done
export DISPLAY=":${display_number}"

Xvfb "$DISPLAY" -screen 0 "${resolution}x24" -nolisten tcp \
  >"${output_dir}/xvfb-${timestamp}.log" 2>&1 &
xvfb_pid=$!
trap 'kill "$xvfb_pid" 2>/dev/null || true' EXIT
export WARP_RECORDING_BENCHMARK_XVFB_PID="$xvfb_pid"
export WARP_RECORDING_BENCHMARK_TICKS_PER_SECOND="$(getconf CLK_TCK)"

for _ in $(seq 1 50); do
  if [[ -S "/tmp/.X11-unix/X${display_number}" ]]; then
    break
  fi
  sleep 0.1
done
if [[ ! -S "/tmp/.X11-unix/X${display_number}" ]]; then
  printf 'Xvfb did not start; see %s\n' "${output_dir}/xvfb-${timestamp}.log" >&2
  exit 1
fi

export WARP_RECORDING_BENCHMARK_OUTPUT="$output"
cargo test --manifest-path "${root}/Cargo.toml" --locked --release -p computer_use \
  benchmark_recording_capture_paths -- \
  --ignored --nocapture --test-threads=1

printf 'Results: %s\n' "$output"
