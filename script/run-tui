#!/bin/bash
#
# Run a local `warp_tui` build.
#
# Selects the internal `local` channel when the `warp-channel-config` generator
# is available (mirroring `./script/run`), otherwise falls back to the OSS
# channel so contributors without repo access can still run the TUI. Unlike the
# GUI `./script/run`, the TUI is a console binary, so there is no `.app` bundle
# step.
#
# The binary is built with `cargo build` and then run directly. On macOS it is
# additionally codesigned with a stable "Apple Development" identity (mirroring
# `./script/macos/run`). Keychain item ACLs key off the code signature, so a
# stable signature means rebuilds don't re-prompt for your keychain password.
# Ad-hoc signatures from a plain `cargo run` change on every build, which is
# what causes repeated prompts.
#
# The TUI is a self-contained console binary (no `.app` bundle), so it is built
# with the `standalone` feature and bundled resources are staged into a sibling
# `resources/` directory next to the executable — mirroring how the GUI's
# `./script/macos/run` stages resources into the `.app` bundle's
# `Contents/Resources` via `prepare_bundled_resources`. At runtime
# `warp_core::paths::bundled_resources_dir()` resolves that sibling directory
# (on macOS via the `standalone` feature, on Linux/Windows unconditionally), and
# the bundled skills loader reads `<resources>/bundled/skills`.
#
# Extra arguments are forwarded to `cargo` (e.g. `--release`); use `--` to
# pass arguments through to the binary itself. Pass `--generate-schema` to also
# generate `settings_schema.json` (needed for the `modify-settings` bundled
# skill to activate); it is skipped by default for a faster dev turnaround.

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"
cd "${REPO_ROOT}"

./script/install_channel_config || echo "Skipping internal channel config installation (no repo access)."

if command -v warp-channel-config &>/dev/null; then
    BIN="warp-tui"
    CHANNEL="local"
else
    BIN="warp-tui-oss"
    CHANNEL="oss"
fi

# Split cargo arguments from binary arguments (after `--`), tracking the
# profile so we can locate the built binary, stage bundled resources next to it,
# and codesign it on macOS.
CARGO_ARGS=()
BIN_ARGS=()
PROFILE_DIR="debug"
GENERATE_SCHEMA=false
while (( "$#" )); do
  case "$1" in
    --)
      shift
      BIN_ARGS=("$@")
      break
      ;;
    --generate-schema)
      GENERATE_SCHEMA=true
      shift
      ;;
    --release)
      PROFILE_DIR="release"
      CARGO_ARGS+=("$1")
      shift
      ;;
    --profile)
      if [ -n "$2" ] && [ "${2:0:1}" != "-" ]; then
        PROFILE_DIR="$2"
        CARGO_ARGS+=("$1" "$2")
        shift 2
      else
        echo "Error: Argument for $1 is missing" >&2
        exit 1
      fi
      ;;
    *)
      CARGO_ARGS+=("$1")
      shift
      ;;
  esac
done

# Build with the `standalone` feature so `warp_core::paths::bundled_resources_dir()`
# resolves the sibling `resources/` directory next to the executable. The TUI is
# a self-contained console binary (not inside a `.app` bundle); without
# `standalone` the macOS resolver would look for a bundle's `Contents/Resources`
# and find nothing. Mirrors the `app` crate's `standalone` feature.
FEATURES="standalone"

# Resolve Cargo's actual target directory rather than assuming ./target (honors
# CARGO_TARGET_DIR / build.target-dir) so we can locate the built binary and
# stage bundled resources next to it. Fall back to the default location when
# `jq` is unavailable (e.g. a minimal Linux dev container).
TARGET_DIR=""
if command -v jq >/dev/null 2>&1; then
  TARGET_DIR="$(cargo metadata --no-deps --format-version 1 | jq -r .target_directory)"
fi
if [ -z "$TARGET_DIR" ] || [ "$TARGET_DIR" = "null" ]; then
  TARGET_DIR="${REPO_ROOT}/target"
fi
TUI_BIN_PATH="${TARGET_DIR}/${PROFILE_DIR}/${BIN}"
RESOURCES_DIR="${TARGET_DIR}/${PROFILE_DIR}/resources"

echo "Building cargo build -p warp_tui --bin ${BIN} --features ${FEATURES} (channel: ${CHANNEL})"
cargo build -p warp_tui --bin "${BIN}" --features "${FEATURES}" "${CARGO_ARGS[@]}"

# Stage bundled resources (including bundled skills) into the sibling `resources/`
# directory the binary resolves at runtime, mirroring how the GUI's
# `./script/macos/run` stages resources into the `.app` bundle's
# `Contents/Resources` via `prepare_bundled_resources`. Licenses and (by
# default) the settings schema are skipped for a fast dev turnaround; pass
# `--generate-schema` to also generate `settings_schema.json`, which the
# `modify-settings` bundled skill requires to activate.
if [ "$GENERATE_SCHEMA" != "true" ]; then
  export SKIP_SETTINGS_SCHEMA=1
fi
echo "Preparing bundled resources in ${RESOURCES_DIR}..."
NO_LICENSES=1 "${REPO_ROOT}/script/prepare_bundled_resources" "${RESOURCES_DIR}" "${CHANNEL}"

if [[ "$(uname -s)" = "Darwin" ]]; then
  SIGNING_CERT="$(security find-identity -p codesigning -v | grep "Apple Development" | awk '{print $2}' | head -1)"
  if [ -n "$SIGNING_CERT" ]; then
    echo "Codesigning ${TUI_BIN_PATH}..."
    codesign --force --sign "$SIGNING_CERT" "$TUI_BIN_PATH"
  else
    echo "Warning: no Apple Development signing identity found; skipping codesign (keychain may re-prompt on rebuilds)." >&2
  fi
fi

exec "$TUI_BIN_PATH" "${BIN_ARGS[@]}"
